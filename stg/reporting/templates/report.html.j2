<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Relatorio STG - Security Toolkit Gateway</title>
<style>
  :root {
    --bg: #0f172a; --card: #1e293b; --text: #e2e8f0; --muted: #94a3b8;
    --critical: #dc2626; --high: #ea580c; --medium: #d97706; --low: #2563eb; --info: #475569;
  }
  * { box-sizing: border-box; }
  body { margin: 0; background: var(--bg); color: var(--text);
    font-family: -apple-system, Segoe UI, Roboto, sans-serif; line-height: 1.5; }
  .wrap { max-width: 960px; margin: 0 auto; padding: 32px 20px; }
  header h1 { margin: 0 0 4px; font-size: 1.6rem; }
  header p { color: var(--muted); margin: 0; }
  .summary { display: flex; flex-wrap: wrap; gap: 12px; margin: 24px 0; }
  .pill { background: var(--card); border-radius: 10px; padding: 12px 18px; min-width: 110px; }
  .pill .n { font-size: 1.6rem; font-weight: 700; }
  .pill .l { color: var(--muted); font-size: .75rem; text-transform: uppercase; letter-spacing: .05em; }
  .block { background: var(--card); border-radius: 12px; padding: 18px 20px; margin: 16px 0; }
  .block h3 { margin: 0 0 4px; }
  .meta { color: var(--muted); font-size: .85rem; margin-bottom: 12px; }
  table { width: 100%; border-collapse: collapse; }
  th, td { text-align: left; padding: 8px 10px; border-bottom: 1px solid #334155; vertical-align: top; }
  th { color: var(--muted); font-size: .75rem; text-transform: uppercase; }
  .badge { display: inline-block; padding: 2px 10px; border-radius: 999px; font-size: .72rem;
    font-weight: 700; color: #fff; text-transform: uppercase; }
  .badge.critical { background: var(--critical); } .badge.high { background: var(--high); }
  .badge.medium { background: var(--medium); } .badge.low { background: var(--low); }
  .badge.info { background: var(--info); }
  .empty { color: var(--muted); font-style: italic; }
  footer { color: var(--muted); font-size: .8rem; margin-top: 28px; text-align: center; }
</style>
</head>
<body>
<div class="wrap">
  <header>
    <h1>STG &middot; Security Toolkit Gateway</h1>
    <p>Relatorio consolidado &middot; {{ generated_at }} &middot; engine v{{ version }}</p>
  </header>

  <section class="summary">
    <div class="pill"><div class="n">{{ total }}</div><div class="l">Total</div></div>
    {% for s in severity_order %}
    <div class="pill"><div class="n">{{ overall[s] }}</div><div class="l">{{ s }}</div></div>
    {% endfor %}
  </section>

  {% for b in blocks %}
  <section class="block">
    <h3>{{ b.connector }}</h3>
    <div class="meta">
      {{ b.category }} &middot; alvo <code>{{ b.target }}</code> &middot; status {{ b.status }}
      {% if b.duration %}&middot; {{ '%.1f' | format(b.duration) }}s{% endif %}
      {% if b.error %}&middot; <span class="empty">{{ b.error }}</span>{% endif %}
    </div>
    {% if b.findings %}
    <table>
      <thead><tr><th>Sev.</th><th>Achado</th><th>Detalhe</th></tr></thead>
      <tbody>
      {% for f in b.findings %}
        <tr>
          <td><span class="badge {{ f.severity.value }}">{{ f.severity.value }}</span></td>
          <td>{{ f.title }}</td>
          <td>{{ f.description }}</td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
    {% else %}
    <p class="empty">Sem achados.</p>
    {% endif %}
  </section>
  {% endfor %}

  <footer>Gerado automaticamente pelo STG &middot; uso restrito a alvos autorizados.</footer>
</div>
</body>
</html>
